{
  "name": "haitaton",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "react-spring-issue-1078": "find node_modules -path \\*@react-spring/\\*/package.json -exec sed -i.bak 's/\"sideEffects\": false/\"sideEffects\": true/g' {} +",
    "postinstall": "npm run react-spring-issue-1078",
    "start": "REACT_APP_DISABLE_SENTRY=1 yarn run update-runtime-env && PORT=3001 react-scripts start",
    "start-msw": "REACT_APP_MOCK_API=use yarn start",
    "build": "react-scripts build",
    "build-and-serve": "yarn run build && yarn run serve",
    "update-runtime-env": "ts-node -P ./scripts/tsconfig.json --files scripts/update-runtime-env.ts",
    "test": "TEST=true yarn run update-runtime-env && react-scripts test",
    "testCI": "TEST=true yarn run update-runtime-env && CI=true react-scripts test --watchAll=false --coverage --maxWorkers=2",
    "test:ci": "TEST=true yarn run update-runtime-env && CI=true react-scripts test --watchAll=false --coverage --maxWorkers=2",
    "test:coverage": "TEST=true yarn run update-runtime-env && CI=true react-scripts test --watchAll=false --coverage --maxWorkers=2",
    "test:watch": "TEST=true yarn run update-runtime-env && react-scripts test --watch",
    "test:debug": "TEST=true yarn run update-runtime-env && react-scripts test --verbose --no-cache",
    "e2e": "playwright test --retries=1 --project=chromium --workers=3",
    "eject": "react-scripts eject",
    "type-check": "tsc --pretty --noEmit",
    "format": "prettier --write",
    "ts-check": "tsc --noEmit --project tsconfig.json",
    "lint": "yarn ts-check && eslint --ext js,ts,tsx src",
    "lint:css": "stylelint 'src/**/*.scss'",
    "locales:export": "ts-node -P ./scripts/tsconfig.json ./scripts/translate-json-to-excel.ts",
    "locales:import": "ts-node -P ./scripts/tsconfig.json ./scripts/translate-excel-to-json.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@chakra-ui/react": "^3.28.0",
    "@emotion/react": "^11.11.3",
    "@emotion/styled": "^11.14.0",
    "@hookform/resolvers": "^3.9.1",
    "@popperjs/core": "^2.11.8",
    "@reduxjs/toolkit": "^2.4.0",
    "@sentry/react": "^8.42.0",
    "@turf/boolean-contains": "^7.1.0",
    "@turf/boolean-equal": "^7.2.0",
    "@turf/boolean-intersects": "^7.1.0",
    "@turf/center": "^7.1.0",
    "@turf/helpers": "^7.1.0",
    "@turf/intersect": "^7.2.0",
    "@turf/kinks": "^7.1.0",
    "@turf/union": "^7.2.0",
    "axios": "^1.8.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.11.17",
    "geojson": "^0.5.0",
    "hds-core": "4.4.0",
    "hds-design-tokens": "4.4.0",
    "hds-react": "4.4.0",
    "i18next": "^23.14.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "lodash": "^4.17.21",
    "ol": "^8.2.0",
    "proj4": "^2.14.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet": "^6.1.0",
    "react-hook-form": "^7.53.2",
    "react-i18next": "^15.0.1",
    "react-query": "^3.39.3",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.27.0",
    "react-scripts": "^5.0.1",
    "react-table": "^7.8.0",
    "sass": "^1.77.6",
    "ts-enum-util": "^4.0.2",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.10.1",
    "@babel/core": "^7.28.4",
    "@babel/plugin-proposal-private-property-in-object": "^7.21.11",
    "@babel/preset-env": "^7.28.3",
    "@faker-js/faker": "^9.6.0",
    "@jridgewell/resolve-uri": "^3.1.2",
    "@mswjs/interceptors": "^0.39.6",
    "@playwright/test": "^1.56.0",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/geojson": "^7946.0.14",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.15.19",
    "@types/proj4": "^2.5.5",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/react-helmet": "^6.1.11",
    "@types/react-redux": "^7.1.33",
    "@types/react-table": "^7.7.20",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "dotenv": "^17.2.3",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-jest": "^28.8.3",
    "http-proxy-middleware": "^3.0.5",
    "husky": "^9.1.7",
    "identity-obj-proxy": "^3.0.0",
    "jest-canvas-mock": "^2.5.2",
    "jest-environment-jsdom": "^30.1.2",
    "jest-fetch-mock": "^3.0.3",
    "jest-junit": "^16.0.0",
    "lint-staged": "^15.2.7",
    "msw": "2.5.2",
    "prettier": "^3.2.5",
    "resize-observer-polyfill": "^1.5.1",
    "stylelint": "^16.11.0",
    "stylelint-config-standard-scss": "^13.1.0",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "undici": "^6.21.0",
    "xlsx": "^0.18.5"
  },
  "resolutions": {
    "immer": "10.1.1",
    "elliptic": "6.6.1",
    "ini": "1.3.8",
    "@babel/traverse": "7.28.4",
    "minimist": "1.2.6"
  },
  "lint-staged": {
    "*.@(js|jsx|ts|tsx)": [
      "yarn lint"
    ],
    "*.@(css|scss)": [
      "yarn lint:css"
    ],
    "*.@(js|jsx|ts|tsx|scss|css|md)": [
      "yarn format"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "eslintConfig": {
    "extends": "react-app"
  },
  "jest": {
    "transformIgnorePatterns": [
      "<rootDir>/node_modules/(?!ol)/"
    ],
    "moduleNameMapper": {
      "^@chakra-ui/utils/context$": "<rootDir>/node_modules/@chakra-ui/utils/dist/cjs/context.cjs",
      "^@chakra-ui/layout$": "<rootDir>/node_modules/@chakra-ui/react/dist/cjs/index.cjs",
      "\\.(css|less|scss)$": "identity-obj-proxy"
    },
    "clearMocks": true,
    "restoreMocks": true,
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*.d.ts",
      "!src/index.tsx",
      "!src/serviceWorker.ts",
      "!src/setupTests.ts",
      "!src/jest.polyfills.js",
      "!src/**/__mocks__/**",
      "!src/**/mocks/**"
    ]
  },
  "msw": {
    "workerDirectory": "public"
  }
}
